# Base de dados PostgreSQL
POSTGRES_PASSWORD=change_me
DB_PASSWORD=change_me

# JWT — mínimo 32 caracteres
JWT_SECRET=change_me_min_32_characters_required

# Token interno Python → Backend (/interno/**)
X_INTERNAL_TOKEN=change_me

# URL do frontend em produção (vazio = nginx proxy local)
FRONTEND_URL=

# URL do backend para o build do frontend (vazio = nginx proxy)
VITE_API_URL=
